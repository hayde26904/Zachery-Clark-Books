<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zachery Clark</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/static/css/styles.css" />
</head>

<body class="index-page">
    <main>
        <header class="page-head wrap">
            <h2 class="mayhem-tagline">THE</h2>
            <h1 class="mayhem-tagline">MAYHEM<br>UNIVERSE</h1>
            <h3 class="mayhem-tagline">TRUTH HIDES IN THE ALLEYS</h3>
            <h2 class="mayhem-tagline author">ZC</h2>
        </header>

        <section class="novels-carousel wrap" aria-label="Novel carousel" id="novels-carousel" data-start-index="<%= initialSlideIndex %>">
            <button class="carousel-btn carousel-btn-prev" type="button" aria-label="Previous novel">&#10094;</button>
            <div class="carousel-track">
                <% books.forEach((book) => { %>
                <section class="book-section fade-section">
                    <div class="book-inner wrap">
                        <div class="cover-shell">
                            <img src="/<%= book.cover %>" class="book-cover" alt="<%= book.coverAlt %>" />
                        </div>
                        <div class="book-copy">
                            <h2 class="book-title"><%- book.title.replace('\n', '<br>') %></h2>
                            <h3 class="book-subtitle"><%= book.subtitle || '\u00A0' %></h3>
                            <div class="book-short-description">
                                <b><%= book.shortDescription %></b>
                            </div>
                            <div class="book-footer">
                                <% if (book.reviews && book.reviews.length > 0) { %>
                                    <div class="book-reviews">
                                    <% book.reviews.forEach((review) => { %>
                                        <% const rating = Number(review.scoreOutOf5.toFixed(1)) || 0; %>
                                        <% const clampedRating = Math.floor(rating); %>
                                        <% const lastStarFillPercent = Math.floor(((rating % 1) * 100)); %>
                                        <div class="book-review">
                                            <div class="book-review-copy">
                                                <p class="book-review-meta">
                                                    <% if (review.url && review.url.trim()) { %>
                                                        <a class="book-review-link" href="<%= review.url %>" target="_blank" rel="noopener noreferrer"><strong><%= review.publicationName %></strong></a> • <%= rating %>/5
                                                    <% } else { %>
                                                        <strong><%= review.publicationName %></strong> • <%= rating %>/5
                                                    <% } %>
                                                </p>
                                                <p class="book-rating-stars" aria-label="Rated <%= rating.toFixed(1) %> out of 5 on <%= review.publicationName %>">
                                                    <% for (let starIndex = 0; starIndex < 5; starIndex++) { %>
                                                        <% const starFillPercentage = (starIndex < clampedRating) ? 100 : lastStarFillPercent %>
                                                        <span class="book-rating-star" aria-hidden="true">
                                                            <span class="book-rating-star-empty">★</span>
                                                            <span class="book-rating-star-filled" style="--star-fill-percentage: <%= starFillPercentage %>%">★</span>
                                                        </span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    <% }); %>
                                    </div>
                                <% } %>
                                <div class="book-links">
                                    <a class="read-more-btn" href="/books/<%= book.slug %>">Read more</a>
                                    <% const externalLinks = Array.isArray(book.links)
                                        ? book.links.flatMap((link) => {
                                            if (!link || typeof link !== 'object') {
                                                return [];
                                            }

                                            if (link.name && link.url) {
                                                return [[link.name, link.url]];
                                            }

                                            return Object.entries(link);
                                        })
                                        : Object.entries(book.links || {}); %>
                                    <% if (externalLinks.length > 0) { %>
                                        <% externalLinks.forEach(([linkText, linkUrl]) => { %>
                                            <% if (linkText && linkUrl) { %>
                                                <a class="read-more-btn" href="<%= linkUrl %>" target="_blank" rel="noopener noreferrer"><%= linkText %></a>
                                            <% } %>
                                        <% }); %>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <% }); %>
            </div>
            <div class="carousel-dots" aria-label="Novel slide indicators"></div>
            <button class="carousel-btn carousel-btn-next" type="button" aria-label="Next novel">&#10095;</button>
        </section>

        <section class="author-section wrap" aria-label="About the author" id="author">
            <div class="author-inner">
                <div class="author-copy author-copy-top">
                    <h2 class="author-title">Author Zachery Clark</h2>
                    <b class="author-tagline">Find your next obsession.</b>
                </div>
                <div class="author-copy author-copy-body">
                    <b class="author-body">Author Bio Here</b>
                </div>
                <div class="author-photo-shell">
                    <img src="/assets/img/scaryzach.jpg" class="author-photo" alt="Portrait of Zachery Clark" />
                </div>
            </div>
        </section>

        <section class="swag-section wrap" aria-label="Swag" id="swag">
            <h2 class="swag-title">Swag</h2>
            <div class="swag-carousel" aria-label="Swag carousel">
                <button class="swag-btn swag-btn-prev" type="button" aria-label="Previous swag item">&#10094;</button>
                <div class="swag-gallery">
                    <% const swagItems = Array.isArray(swagPreview) ? swagPreview : []; %>
                    <% swagItems.forEach((item, itemIndex) => { %>
                        <% const itemUrl = item.url && item.url.trim() ? item.url : 'https://zachery-clark-books.myshopify.com/collections/swag'; %>
                        <a class="swag-card" href="<%= itemUrl %>" aria-label="View swag item <%= itemIndex + 1 %> in store" target="_blank" rel="noopener noreferrer">
                            <img src="<%= item.image %>" class="swag-item" alt="Swag item <%= itemIndex + 1 %>" />
                        </a>
                    <% }); %>
                </div>
                <button class="swag-btn swag-btn-next" type="button" aria-label="Next swag item">&#10095;</button>
            </div>
            <a class="read-more-btn swag-store-link" href="https://zachery-clark-books.myshopify.com/collections/swag">View Store</a>
        </section>

        <section class="newsletter-section wrap" aria-label="Newsletter signup" id="newsletter">
            <h2 class="newsletter-title">Newsletter</h2>
            <p class="newsletter-copy">Get updates on new releases, events, and fresh swag drops!</p>
            <form class="newsletter-form" method="post" action="https://onrender.us22.list-manage.com/subscribe/post?u=36b67d7df8372227f1eedd497&id=6c3a0e9836&f_id=00bcc2e1f0">
                <input type="hidden" name="form_type" value="customer">
                <input type="hidden" name="utf8" value="✓">
                <label class="newsletter-label" for="newsletter-email">Email address</label>
                <input id="newsletter-email" name="EMAIL" class="newsletter-input" type="email" autocomplete="email" placeholder="you@example.com" required />
                <label class="newsletter-consent" for="newsletter-consent">
                    <input id="newsletter-consent" name="CONSENT" type="checkbox" required />
                    I agree to receive marketing emails.
                </label>
                <button class="read-more-btn newsletter-btn" type="submit">Sign up</button>
            </form>

            

        </section>
    </main>

    <script src="/static/js/script.js"></script>
</body>

</html>
